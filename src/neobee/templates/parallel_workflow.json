{
  "name": "parallel_workflow",
  "description": "并行执行多个独立任务的工作流",
  "version": "2.0.0",
  "variables": {
    "target": "example.com",
    "wordlist": "/usr/share/wordlists/dirb/common.txt"
  },
  "steps": [
    {
      "id": "port_scan",
      "order": 1,
      "name": "端口扫描",
      "tool": "nmap",
      "args": {
        "-sV": true,
        "target": "{{target}}"
      },
      "save_result_as": "port_scan_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": false
    },
    {
      "id": "subdomain_enum",
      "order": 2,
      "name": "子域名枚举",
      "tool": "subfinder",
      "parallel_group": "recon",
      "args": {
        "domain": "{{target}}"
      },
      "save_result_as": "subdomain_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "dns_enum",
      "order": 2,
      "name": "DNS 枚举",
      "tool": "dnsenum",
      "parallel_group": "recon",
      "args": {
        "domain": "{{target}}"
      },
      "save_result_as": "dns_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "whois_lookup",
      "order": 2,
      "name": "WHOIS 查询",
      "tool": "whois",
      "parallel_group": "recon",
      "args": {
        "domain": "{{target}}"
      },
      "save_result_as": "whois_result",
      "timeout": 60,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "web_scan",
      "order": 3,
      "name": "Web 扫描",
      "tool": "ffuf",
      "depends_on": ["port_scan"],
      "args": {
        "--wordlist": "{{wordlist}}",
        "target": "{{target}}"
      },
      "save_result_as": "web_scan_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "vuln_scan",
      "order": 3,
      "name": "漏洞扫描",
      "tool": "nuclei",
      "depends_on": ["port_scan"],
      "parallel_group": "scan",
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "vuln_result",
      "timeout": 600,
      "retry": 1,
      "continue_on_error": true
    }
  ]
}
