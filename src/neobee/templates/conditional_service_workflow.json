{
  "name": "conditional_service_workflow",
  "description": "根据扫描结果中的服务类型决定执行不同步骤", 
  "version": "2.0.0",
  "variables": {
    "target": "example.com"
  },
  "steps": [
    {
      "id": "detect_services",
      "order": 1,
      "name": "识别服务",
      "tool": "service_detector",
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "service_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": false
    },
    {
      "id": "http_check",
      "order": 2,
      "name": "执行 HTTP 检查",
      "tool": "http_checker",
      "depends_on": ["detect_services"],
      "when": {
        "type": "contains",
        "source": "service_result.services",
        "value": "http"
      },
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "http_check_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "ssh_check",
      "order": 2,
      "name": "执行 SSH 检查",
      "tool": "ssh_checker",
      "depends_on": ["detect_services"],
      "when": {
        "type": "contains",
        "source": "service_result.services",
        "value": "ssh"
      },
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "ssh_check_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "generic_check",
      "order": 2,
      "name": "执行通用检查",
      "tool": "generic_checker",
      "depends_on": ["detect_services"],
      "when": {
        "type": "not_contains_any",
        "source": "service_result.services",
        "values": ["http", "ssh"]
      },
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "generic_check_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    }
  ]
}