{
  "name": "conditional_web_workflow",
  "description": "扫描到 HTTP 端口时执行 Web 探测，否则执行其他步骤",
  "version": "2.0.0",
  "variables": {
    "target": "example.com",
    "wordlist": "/usr/share/wordlists/dirb/common.txt",
    "http_ports": [80, 443, 8080, 8443]
  },
  "steps": [
    {
      "id": "port_scan",
      "order": 1,
      "name": "端口扫描",
      "tool": "nmap",
      "args": {
        "-sV": true,
        "target": "{{target}}"
      },
      "save_result_as": "port_scan_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": false
    },
    {
      "id": "web_fuzz",
      "order": 2,
      "name": "Web 路径扫描",
      "tool": "ffuf",
      "depends_on": ["port_scan"],
      "when": {
        "type": "contains_any",
        "source": "port_scan_result.open_ports",
        "values": "{{http_ports}}"
      },
      "args": {
        "--wordlist": "{{wordlist}}",
        "target": "{{target}}"
      },
      "save_result_as": "web_fuzz_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    },
    {
      "id": "service_enum",
      "order": 2,
      "name": "非 Web 服务枚举",
      "tool": "service_scan",
      "depends_on": ["port_scan"],
      "when": {
        "type": "not_contains_any",
        "source": "port_scan_result.open_ports",
        "values": "{{http_ports}}"
      },
      "args": {
        "target": "{{target}}"
      },
      "save_result_as": "service_enum_result",
      "timeout": 300,
      "retry": 1,
      "continue_on_error": true
    }
  ]
}